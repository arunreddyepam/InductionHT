<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd" >
<suite name="CalculatorSuite" parallel="methods" thread-count="4">
    <listeners>
        <listener class-name="org.example.testNG.Task1UnitTesting.CustomListener"/>
    </listeners>
    <test name="CalculatorTests">
        <groups>
            <run>
                <include name="positive"/>
                <include name="negative"/>
            </run>
        </groups>
        <classes>
            <class name="org.example.testNG.Task1UnitTesting.CalculatorTest"/>
        </classes>
    </test>
</suite>