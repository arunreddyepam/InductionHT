<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<suite name="CrossBrowserParallelSuite" parallel="tests" thread-count="3">

    <listeners>
        <listener class-name="org.example.listeners.ExtentReportListener"/>
    </listeners>

    <test name="Chrome_Login_Test">
        <parameter name="browser" value="chrome"/>
        <classes>
            <class name="org.example.tests.ChromeLoginTest"/>
        </classes>
    </test>

    <test name="Firefox_Login_Test">
        <parameter name="browser" value="firefox"/>
        <classes>
            <class name="org.example.tests.FirefoxLoginTest"/>
        </classes>
    </test>

    <test name="Edge_Login_Test">
        <parameter name="browser" value="edge"/>
        <classes>
            <class name="org.example.tests.EdgeLoginTest"/>
        </classes>
    </test>

</suite>