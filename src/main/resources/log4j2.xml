<?xml version="1.0" encoding="UTF-8"?>
<Configuration status="WARN">

    <Properties>
        <!-- User-specific custom format -->
        <Property name="LOG_PATTERN">
            [%d{yyyy-MM-dd HH:mm:ss}] [%-5level] [%t] [%C{1}.%M:%L] - %msg%n
        </Property>
        <Property name="LOG_DIR">logs</Property>
    </Properties>

    <Appenders>
        <!-- 1. Console Appender -->
        <Console name="ConsoleAppender" target="SYSTEM_OUT">
            <PatternLayout pattern="${LOG_PATTERN}"/>
        </Console>

        <!-- 2. File Appender (logs to a file) -->
        <File name="FileAppender" fileName="${LOG_DIR}/automation.log">
            <PatternLayout pattern="${LOG_PATTERN}"/>
        </File>

        <!-- 3. Rolling File Appender (daily rotation) -->
        <RollingFile name="RollingFileAppender"
                     fileName="${LOG_DIR}/automation-current.log"
                     filePattern="${LOG_DIR}/automation-%d{yyyy-MM-dd}-%i.log">
            <PatternLayout pattern="${LOG_PATTERN}"/>
            <Policies>
                <TimeBasedTriggeringPolicy interval="1"/>
                <SizeBasedTriggeringPolicy size="10 MB"/>
            </Policies>
            <DefaultRolloverStrategy max="10"/>
        </RollingFile>
    </Appenders>

    <Loggers>
        <Root level="debug">
            <AppenderRef ref="ConsoleAppender"/>
            <AppenderRef ref="FileAppender"/>
            <AppenderRef ref="RollingFileAppender"/>
        </Root>
    </Loggers>
</Configuration>